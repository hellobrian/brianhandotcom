---
import type { CollectionEntry } from "astro:content";

import StandardBlogPostLayout from "./StandardBlogPostLayout.astro";
import PhotoBlogPostLayout from "./PhotoBlogPostLayout.astro";

type Props = CollectionEntry<"blog">["data"];

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  variant,
  cover,
  coverAlt,
  isPublished,
} = Astro.props;
---

{
  variant === "photo" && (
    <PhotoBlogPostLayout
      title={title}
      description={description}
      pubDate={pubDate}
      updatedDate={updatedDate}
      tags={tags}
      cover={cover}
      coverAlt={coverAlt}
      isPublished={isPublished}
      variant={variant}
    >
      <slot />
    </PhotoBlogPostLayout>
  )
}
{
  variant === "standard" && (
    <StandardBlogPostLayout
      title={title}
      description={description}
      pubDate={pubDate}
      updatedDate={updatedDate}
      tags={tags}
      cover={cover}
      coverAlt={coverAlt}
      isPublished={isPublished}
      variant={variant}
    >
      <slot />
    </StandardBlogPostLayout>
  )
}
