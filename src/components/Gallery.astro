---
interface ImageData {
  src: string;
  alt: string;
}

interface Props {
  images: ImageData[];
  description?: string[] | string;
  alignment?: "start" | "end";
  id?: string;
  links?: { label: string; href: string }[];
}

const { images, alignment = "start", id = "gallery-dialog" } = Astro.props;
---

<section class="container">
  <div class="gallery">
    {
      images.map((image) => (
        <div class="gallery-item">
          <img src={image.src} alt={image.alt} />
          <button
            aria-label="open gallery"
            type="button"
            data-trigger={`gallery-dialog-trigger-${id}`}
          />
        </div>
      ))
    }
  </div>
  <div
    class="description"
    style={alignment === "start"
      ? { alignSelf: "start", top: 0 }
      : { alignSelf: "end", bottom: 0 }}
  >
    <slot />
  </div>
</section>

<dialog id={id}>
  <div class="dialog-content">
    <button autofocus class="close-button">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        xml:space="preserve"
        width="121.31"
        height="122.876"
        viewBox="0 0 121.31 122.876"
        ><path
          fill-rule="evenodd"
          d="M90.914 5.296a17.66 17.66 0 0 1 25.154-.068c6.961 6.995 6.991 18.369.068 25.397L85.743 61.452l30.425 30.855c6.866 6.978 6.773 18.28-.208 25.247-6.983 6.964-18.21 6.946-25.074-.031L60.669 86.881 30.395 117.58a17.66 17.66 0 0 1-25.154.068c-6.961-6.995-6.992-18.369-.068-25.397l30.393-30.827L5.142 30.568c-6.867-6.978-6.773-18.28.208-25.247 6.983-6.963 18.21-6.946 25.074.031l30.217 30.643z"
          clip-rule="evenodd"></path></svg
      >
    </button>
    {images.map((image) => <img src={image.src} alt={image.alt} />)}
  </div>
</dialog>

<script is:inline define:vars={{ id }}>
  const dialog = document.getElementById(id);
  const triggerList = document.querySelectorAll(
    `[data-trigger='gallery-dialog-trigger-${id}']`,
  );

  if (triggerList && dialog) {
    triggerList.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        dialog.showModal();
      });
    });

    dialog.querySelector("button")?.addEventListener("click", () => {
      dialog.close();
    });
  }
</script>

<!-- Dialog styles -->
<style>
  dialog {
    inline-size: 100%;
    block-size: 100%;
    background: rgb(var(--black));
  }
  .dialog-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    /* background: rgb(var(--black)); */
  }
  .dialog-content .close-button {
    position: fixed;
    bottom: 1rem;
    inline-size: 44px;
    block-size: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: none;
    background: white;
    border: 2px solid transparent;
    color: rgb(var(--black));
  }

  .dialog-content .close-button svg {
    width: 20px;
    height: 20px;
  }

  .dialog-content .close-button:hover {
    cursor: pointer;
  }

  .dialog-content .close-button:focus {
    outline: 4px solid var(--accent-light);
  }
</style>

<!-- Gallery styles -->
<style>
  /* container */
  .container {
    position: relative;
    display: grid;
    grid-template-areas: "gallery description";
    grid-template-columns: 960px 1fr;
    gap: 2rem;
    inline-size: min(100%, 1600px);
    margin: 0 auto;
  }

  @media screen and (width < 1280px) {
    .container {
      grid-template-areas:
        "gallery"
        "description";
      grid-template-columns: 1fr;
    }
  }

  /* gallery */
  .container > .gallery {
    grid-area: gallery;
    position: relative;
    padding-block-start: 0rem;
    align-self: start;
    display: grid;
    gap: 1rem;
    margin-block-end: 1rem;
  }

  .container > .gallery * {
    inline-size: 100%;
  }

  @media screen and (width < 1280px) {
    .container > .gallery {
      position: relative;
      display: flex;
      align-items: flex-start;
      padding: 0;
      margin: 0;
      scroll-snap-type: x mandatory;
      overflow-x: scroll;
      overflow-y: hidden;
      scroll-behavior: smooth;
    }

    .container > .gallery > * {
      flex: 0 0 auto;
      scroll-snap-align: start;
      width: 100%;
      margin-right: 1rem;
      aspect-ratio: 16 / 9;
      object-fit: contain;
      border-radius: 8px;
    }
  }

  /* gallery item */
  .gallery-item {
    display: grid;
  }

  .gallery-item > * {
    grid-column: 1;
    grid-row: 1;
  }

  .gallery-item > button {
    background: rgba(0, 0, 0, 0);
    background: none;
    padding: 0;
    margin: 0;
    border: none;
    cursor: pointer;
    border-radius: 8px;
  }

  .gallery-item > button:focus {
    outline: 4px solid var(--accent-light);
    outline-offset: 2px;
  }

  .gallery-item > button:hover {
    background: rgba(0, 0, 0, 0.1);
    transition:
      box-shadow 200ms ease-in-out,
      background 200ms ease-in-out;
    cursor: pointer;
    box-shadow: var(--box-shadow);
  }

  .gallery-item > img {
    object-fit: cover;
  }

  /* description */
  .container > .description {
    grid-area: description;
    position: sticky;
    margin-block-end: 1rem;
    padding-block-end: 1rem;
  }

  @media screen and (width < 1280px) {
    .container > .description {
      position: relative;
      bottom: auto;
      align-self: auto;
      margin-block-end: 0;
      padding-block-end: 0;
    }
  }

  .container > .description > p:first-child {
    margin-block-start: 1rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    block-size: fit-content;
  }
</style>
