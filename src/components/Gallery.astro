---
interface ImageData {
  src: string;
  alt: string;
}

interface Props {
  images: ImageData[];
  description: string[];
}

const { images, description } = Astro.props;
---

<section class="container">
  <div class="gallery">
    {images.map((image) => <img src={image.src} alt={image.alt} />)}
  </div>
  <div class="description">
    {description.map((paragraph) => <p>{paragraph}</p>)}
  </div>
</section>

<style>
  .container {
    position: relative;
    display: grid;
    grid-template-areas: "gallery description";
    grid-template-columns: 960px 1fr;
    gap: 2rem;
    inline-size: min(100%, 1440px);
    margin: 0 auto;
  }

  @media screen and (width < 1280px) {
    .container {
      grid-template-areas:
        "gallery"
        "description";
      grid-template-columns: 1fr;
    }
  }

  .container > .gallery {
    grid-area: gallery;
    position: relative;
    padding-block-start: 0rem;
    align-self: start;
  }

  .container > .gallery > img {
    inline-size: 100%;
  }

  @media screen and (width < 1280px) {
    .container > .gallery {
      position: relative;
      display: flex;
      align-items: flex-start;
      padding: 0;
      margin: 0;
      scroll-snap-type: x mandatory;
      overflow-x: scroll;
      overflow-y: hidden;
      scroll-behavior: smooth;
    }

    .container > .gallery > img {
      flex: 0 0 auto;
      scroll-snap-align: start;
      width: 100%;
      margin-right: 1rem;
      aspect-ratio: 1.5;
      object-fit: contain;
      border-radius: 8px;
    }
  }

  .container > .description {
    grid-area: description;
    position: sticky;
    top: 0;
    align-self: start;
    margin-block-end: 1rem;
    padding-block-end: 1rem;
  }

  @media screen and (width < 1280px) {
    .container > .description {
      position: relative;
      bottom: auto;
      align-self: auto;
      margin-block-end: 0;
      padding-block-end: 0;
    }
  }

  .container > .description > p:first-child {
    margin-block-start: 1rem;
  }
</style>
